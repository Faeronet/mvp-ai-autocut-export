# Core
APP_ENV=development
LOG_LEVEL=info
HTTP_ADDR=:8080
DATA_DIR=./data

# Database
POSTGRES_DSN=postgres://drawdigit:drawdigit@localhost:5432/drawdigit?sslmode=disable

# Redis / queue
REDIS_ADDR=localhost:6379

# ML service URLs (compose defaults shown)
LAYOUT_SERVICE_URL=http://localhost:8001
OCR_SERVICE_URL=http://localhost:8002
VECTOR_SERVICE_URL=http://localhost:8003
EXPORT_SERVICE_URL=http://localhost:8004

# Model cache & bootstrap (see docs/model-management.md)
MODEL_AUTO_DOWNLOAD=true
MODEL_STARTUP_STRICT=true
# Compose only: if bootstrap-models logs "Temporary failure in name resolution", set DNS for that service:
# BOOTSTRAP_DNS_1=1.1.1.1
# BOOTSTRAP_DNS_2=8.8.8.8
MODEL_CACHE_DIR=./data/models_cache
OCR_BACKEND=paddleocr
OCR_LANG=ru
OCR_DET_MODEL_NAME=ppocrv4_det
OCR_REC_MODEL_NAME=ppocrv4_rec
OCR_CLS_MODEL_NAME=ppocrv4_cls
LAYOUT_BACKEND=yolov8n
LAYOUT_MODEL_NAME=yolov8n_layout
LAYOUT_MODEL_WEIGHTS=./data/models_cache/layout/yolov8n_layout.pt
TABLE_BACKEND=paddle_table
TABLE_MODEL_NAME=ppstructure_slanet
SHEET_CLASSIFIER_BACKEND=rules
ENABLE_MODEL_SHEET_CLASSIFIER=false
SYMBOL_DETECTION_BACKEND=heuristic
ENABLE_SYMBOL_DETECTION=true
SYMBOL_MODEL_AUTO_DOWNLOAD=false
REVIEW_BACKEND=rules
ENABLE_LOW_CONFIDENCE_REVIEW=true
ENABLE_LLM_REVIEW_FALLBACK=false
 
# GPU scheduling
PROFILE_GPU=PROFILE_GPU_12GB
MAX_PARALLEL_JOBS=2
MAX_GPU_TASKS=1
GPU_SEMAPHORE_KEY=gpu:global_lock
GPU_LOCK_TTL=30m
OCR_USE_GPU=true
LAYOUT_USE_GPU=true
OCR_BATCH_SIZE=1
LAYOUT_BATCH_SIZE=1
TILE_SIZE=512
MAX_IMAGE_SIDE=2048
FP16_ENABLED=true
TORCH_CUDA_ALLOC_CONF=max_split_size_mb:128
# Docker ML: single GPU for PaddleOCR + YOLO (layout + ocr containers). Requires NVIDIA drivers + Container Toolkit.
# CUDA_VISIBLE_DEVICES=0
# ML_REQUIRE_GPU=true
#   If true, services exit at startup if CUDA is missing (no CPU fallback for neural models). Set false only for CPU-only dev images.

# Profiles (reference)
# PROFILE_GPU_8GB: lower MAX_IMAGE_SIDE, TILE_SIZE
# PROFILE_GPU_16GB: higher fidelity defaults

# Mock pipeline (CI / no ML)
MOCK_PIPELINE=false

# HTTP / CORS / MCP
# For UI/API from another machine: use * (permissive) or list explicit origins, e.g.
# CORS_ALLOWED_ORIGINS=http://203.0.113.10,http://myhost.example:80
CORS_ALLOWED_ORIGINS=*
MCP_ALLOWED_HOSTS=*,localhost,127.0.0.1
SESSION_SECRET=change-me
MCP_HTTP_ADDR=:8090

# Timeouts
HTTP_CLIENT_TIMEOUT=120s
