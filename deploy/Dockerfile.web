FROM node:20-bookworm AS build
WORKDIR /app
COPY apps/web/package.json apps/web/package-lock.json* ./
RUN set -eux; \
    if [ -f package-lock.json ]; then \
      for i in 1 2 3; do npm ci --no-audit --no-fund && break || (echo "npm ci retry $i"; rm -rf node_modules); done; \
    else \
      for i in 1 2 3; do npm install --no-audit --no-fund && break || (echo "npm install retry $i"; rm -rf node_modules); done; \
    fi
COPY apps/web .
RUN npm run build

FROM nginx:1.27-alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
